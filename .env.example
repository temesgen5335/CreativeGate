# CreativeGate service configuration.
# Copy to .env (gitignored) or set these in your platform's variable UI.
# Every variable is optional — with none set you get a working keyless,
# open, local-paths deployment (honestly labeled lower-fidelity).

# --- Service -----------------------------------------------------------------
# Required the moment the URL is reachable by anyone but you.
CREATIVEGATE_API_TOKEN=

# Injected automatically by Railway/most PaaS; set manually elsewhere.
# PORT=8000
# CREATIVEGATE_HOST=0.0.0.0

# --- State (point all three at the persistent volume) -------------------------
CREATIVEGATE_DB=/data/creativegate.db
CREATIVEGATE_ARTIFACT_DIR=/data/artifacts
CREATIVEGATE_CACHE_DIR=/data/model-cache

# --- Judge LLM (optional upgrade from the keyless heuristic) ------------------
# Keys are used by exactly one thing: the judge rung's pairwise comparator.
# EVERY configured provider below joins a fallback chain — a provider that
# errors goes on a 60s cooldown and the next one answers; the chain ends in
# the deterministic heuristic, which cannot fail. Zero keys still works
# (labeled "degraded"). The verdict's evidence names whichever provider
# actually answered.

# Preferred provider tried first: openai | groq | gemini | openrouter | anthropic
LLM_PROVIDER=groq

# Configure any subset — each key enables that provider in the chain:
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (defaults shown):
# OPENAI_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_MODEL=gemini-2.0-flash
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Custom OpenAI-compatible endpoint (a gateway, a local model, …) — always
# ranks first in the chain when set:
# CREATIVEGATE_LLM_API_KEY=
# CREATIVEGATE_LLM_BASE_URL=https://my-gateway.example/v1
# CREATIVEGATE_LLM_MODEL=my-model

# --- Misc ----------------------------------------------------------------------
# CREATIVEGATE_MAX_UPLOAD_MB=25
# CREATIVEGATE_CORS_ORIGINS=https://app.example.com
