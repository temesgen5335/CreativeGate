# CreativeGate service configuration.
# Copy to .env (gitignored) or set these in your platform's variable UI.
# Every variable is optional — with none set you get a working keyless,
# open, local-paths deployment (honestly labeled lower-fidelity).

# --- Service -----------------------------------------------------------------
# Required the moment the URL is reachable by anyone but you.
CREATIVEGATE_API_TOKEN=

# Injected automatically by Railway/most PaaS; set manually elsewhere.
# PORT=8000
# CREATIVEGATE_HOST=0.0.0.0

# --- State (point all three at the persistent volume) -------------------------
CREATIVEGATE_DB=/data/creativegate.db
CREATIVEGATE_ARTIFACT_DIR=/data/artifacts
CREATIVEGATE_CACHE_DIR=/data/model-cache

# --- Judge LLM (optional upgrade from the keyless heuristic) ------------------
# The LLM slot speaks to ANY OpenAI-compatible endpoint. Pick one block.
#
# OpenAI (default base URL):
# OPENAI_API_KEY=sk-...
# CREATIVEGATE_LLM_MODEL=gpt-4o-mini
#
# Groq:
# CREATIVEGATE_LLM_API_KEY=gsk_...
# CREATIVEGATE_LLM_BASE_URL=https://api.groq.com/openai/v1
# CREATIVEGATE_LLM_MODEL=llama-3.1-8b-instant
#
# OpenRouter:
# CREATIVEGATE_LLM_API_KEY=sk-or-...
# CREATIVEGATE_LLM_BASE_URL=https://openrouter.ai/api/v1
# CREATIVEGATE_LLM_MODEL=anthropic/claude-3.5-haiku
#
# Gemini (OpenAI-compatible endpoint):
# CREATIVEGATE_LLM_API_KEY=AIza...
# CREATIVEGATE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# CREATIVEGATE_LLM_MODEL=gemini-2.0-flash

# --- Misc ----------------------------------------------------------------------
# CREATIVEGATE_MAX_UPLOAD_MB=25
# CREATIVEGATE_CORS_ORIGINS=https://app.example.com
